# Polymarket MoneyMaker V3 paper engine config

# =========================
# PAPER ACCOUNT
# =========================
INITIAL_CASH=250
BASE_ORDER_USD=10
MIN_ORDER_USD=3

# =========================
# DATA / DISCOVERY
# =========================
ENABLE_WS=false
HUNTER_MODE=true
MAX_MARKETS=20
EVENT_LIMIT=100
EVENT_PAGES=2
REFRESH_RESEARCH_EVERY=10

# =========================
# MARKET FILTERS
# =========================
MIN_LIQUIDITY=500
MIN_VOLUME_24H=50
MIN_BEST_BID=0.02
MAX_BEST_ASK=0.98
MAX_SPREAD=0.18
HUNTER_MAX_SPREAD=0.22
HUNTER_MIN_TOP_DEPTH_USD=5
HUNTER_MAX_TOP_DEPTH_USD=4000

# =========================
# RISK LIMITS
# =========================
MAX_POSITION_USD=200
MAX_MARKET_EXPOSURE_USD=350
MAX_TOTAL_EXPOSURE_USD=300
MAX_TOTAL_OPEN_ORDER_USD=250
MAX_OPEN_ORDERS=50
MAX_DRAWDOWN_PCT=12

# =========================
# SIGNAL QUALITY
# =========================
MIN_SIGNAL_EDGE=0.008
MIN_CONFIDENCE=0.45
SLIPPAGE_BUFFER=0.004
ADVERSE_SELECTION_BUFFER=0.006

# =========================
# STOP LOSS / TAKE PROFIT
# =========================
STOP_LOSS_PCT=8
ENABLE_TAKE_PROFIT=true
TAKE_PROFIT_PCT=18

# =========================
# VOLATILITY GUARD
# =========================
VOL_TRIP_PCT=12
VOL_COOLDOWN_MS=5000
VOL_EDGE_MULTIPLIER=1.75
QUOTE_DURING_VOL=false

# =========================
# FILL REALISM / QUEUE REALISM
# =========================
PARTIAL_FILL_DEPTH_FRACTION=0.35
MIN_FILL_USD=1
LIQUIDITY_CONSUMED_LIMIT_PCT=0.20
LIQUIDITY_DECAY_POWER=6.0

# =========================
# GHOST ORDER CALIBRATION
# =========================
ENABLE_GHOST_MODE=true
GHOST_HORIZON_MS=60000
GHOST_MAX_RECORDS=500

# =========================
# MULTI-VIEW CONSENSUS / SOPHIE
# =========================
ENABLE_CONSENSUS=true
CONSENSUS_THRESHOLD=0.60
CONSENSUS_LOG_REJECTED=true
CONSENSUS_BOOST_MAX=1.15
CONSENSUS_PENALTY_MIN=0.70
CONSENSUS_STABLE_MAX_SPREAD=0.12
CONSENSUS_TREND_MOVE_PCT=0.035
CONSENSUS_SNIPER_SIZE_MULTIPLIER=0.65
CONSENSUS_MAKER_BOOST=1.05

# =========================
# MAKER ROUTING
# =========================
TARGET_WALLET_MODE=true
TARGET_WALLET_HANDLE=gabagool22
TARGET_WALLET_DISPLACEMENT_PCT=0.015
MAKER_SPREAD_MULTIPLIER=1.2

# =========================
# ORDER BOOK IMBALANCE
# =========================
ENABLE_IMBALANCE_SIGNALS=true
IMBALANCE_DEPTH_LEVELS=3
IMBALANCE_STRONG_THRESHOLD=0.25
IMBALANCE_BALANCED_THRESHOLD=0.12

# =========================
# ADAPTIVE POSITION SIZING
# =========================
ENABLE_ADAPTIVE_SIZING=true
ADAPTIVE_MIN_SIZE_MULTIPLIER=0.35
ADAPTIVE_MAX_SIZE_MULTIPLIER=1.35
ADAPTIVE_GHOST_PENALTY=0.65

# =========================
# WHALE TRACKING
# =========================
ENABLE_WHALE_TRACKING=true
ENABLE_WHALE_COPY_STRATEGY=true
WHALE_DATA_API_URL=https://data-api.polymarket.com
WHALE_WALLETS=0x327576572a9df273017d23d8438139be6587c47d,0xe661b17a0d638706037a3641320078864010371a,0x789b7054f026a27e7d70404c459990529d666666,0x66c888d22791404179373d57d59b2f63f6834b97,0x0f3408f6153093952f44c45b533668a688888888,0x1f5c6e7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e,0x2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b,0x3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d,0x4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e,0x5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f,0x6031b6eed1c97e853c6e0f03ad3ce3529351f96d
WHALE_POLL_MS=30000
WHALE_LOOKBACK_MS=120000
WHALE_MIN_USD=5000
WHALE_TRADES_LIMIT=50
WHALE_API_TIMEOUT_MS=8000
WHALE_BATCH_SIZE=3
WHALE_BATCH_DELAY_MS=1000
WHALE_COPY_FRESH_MS=30000
WHALE_COPY_BASE_MULTIPLIER=0.4
WHALE_COPY_WHALE_FRACTION=0.15

# =========================
# STRATEGIES
# =========================
STRAT_COMPLEMENT_ARB=true
STRAT_SPREAD_HUNTER=true
STRAT_INVENTORY_EXIT=true
STRAT_TAIL_END=true

# =========================
# CLOB WEBSOCKET
# =========================
WS_HEARTBEAT_ENABLED=true
WS_HEARTBEAT_MS=10000
WS_RECONNECT_INITIAL_MS=5000
WS_RECONNECT_MAX_MS=60000
